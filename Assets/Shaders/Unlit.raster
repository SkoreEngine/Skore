
#include "Bindings.hlsli"

struct PushConstants
{
	matrix world;
	uint   meshIndex;
	uint   vertexLayoutIndex;
	uint2  pad;
};

[[vk::push_constant]] PushConstants pushConstants;

struct PixelInput
{
	float4 position : SV_POSITION;
};

PixelInput MainVS(uint vertexId : SV_VertexID)
{
	PixelInput output;
	float3 position = GetVertexPosition(pushConstants.meshIndex, pushConstants.vertexLayoutIndex, vertexId);
	float4 worldPosition = mul(pushConstants.world, float4(position, 1.0f));
	output.position      = mul(viewProjection, worldPosition);
	return output;
}

// Pixel Shader
float4 MainPS(PixelInput input) : SV_TARGET
{
    return 1.0;
}
