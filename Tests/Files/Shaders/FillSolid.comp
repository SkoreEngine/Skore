// Writes a fixed colour to every texel of a storage texture. Used to verify the render graph's
// declarative compute path: graph-bound descriptor set + auto dispatch (the graph divides the
// requested size by the shader's [numthreads], so 64x64 / 8x8 must cover the whole image).

[[vk::binding(0)]] [[vk::image_format("rgba32f")]] RWTexture2D<float4> outputTexture;

[numthreads(8, 8, 1)]
void MainCS(uint3 id : SV_DispatchThreadID)
{
    outputTexture[id.xy] = float4(0.2, 0.4, 0.6, 1.0);
}
