// Writes a colour supplied via push constants to a storage texture. Used to verify RenderGraphPass::
// Constants<T>: the graph must push the constant with the shader's actual stage (Compute), and the
// value must arrive intact (checked by reading the texel back).

struct PushConstants
{
    float4 color;
};

[[vk::push_constant]] PushConstants pushConstants;

[[vk::binding(0)]] [[vk::image_format("rgba32f")]] RWTexture2D<float4> outputTexture;

[numthreads(8, 8, 1)]
void MainCS(uint3 id : SV_DispatchThreadID)
{
    outputTexture[id.xy] = pushConstants.color;
}
